{
	"name": "openfin-web--web-client-api",
	"version": "23.0.0",
	"description": "OpenFin Web Starter -- Web Client API",
	"main": "public/js/web.client.api.bundle.js",
	"scripts": {
		"client": "node ./scripts/launch.mjs",
		"build-client": "webpack build --config ./client/webpack.config.js --mode=production",
		"build": "npm run build-client",
		"start": "npx --yes http-server ./public -p 6060 -c-1",
		"setup": "npm install && npm run build"
	},
	"author": "john.mandia@here.io",
	"license": "SEE LICENSE IN LICENSE.MD",
	"dependencies": {
		"@finos/fdc3": "2.0.3",
		"@openfin/core-web": "0.43.115"
	},
	"devDependencies": {
		"@openfin/core": "43.101.4",
		"ts-loader": "^9.5.1",
		"typescript": "^5.4.2",
		"webpack": "^5.90.3",
		"webpack-cli": "^5.1.4"
	}
}
