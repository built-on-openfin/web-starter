{
	"name": "openfin-web--cloud-interop-basic",
	"version": "23.0.0",
	"description": "OpenFin Web Starter -- Cloud Interop - Basic",
	"main": "public/platform/provider.bundle.js",
	"scripts": {
		"client": "node ./scripts/launch.mjs",
		"copy-shared-worker": "node ./scripts/copy-shared-worker.js",
		"build-client": "npm run copy-shared-worker && webpack build --config ./client/webpack.config.js --mode=development",
		"build": "npm run build-client",
		"start": "npx --yes http-server ./public -p 6060 -c-1",
		"setup": "npm install && npm run build"
	},
	"author": "john.mandia@here.io",
	"license": "SEE LICENSE IN LICENSE.MD",
	"dependencies": {
		"@finos/fdc3": "2.0.3",
		"@openfin/cloud-interop": "0.43.112",
		"@openfin/core-web": "0.43.112"
	},
	"devDependencies": {
		"@openfin/core": "43.101.1",
		"copy-webpack-plugin": "^13.0.1",
		"ts-loader": "^9.5.1",
		"typescript": "^5.4.2",
		"webpack": "^5.90.3",
		"webpack-cli": "^5.1.4"
	}
}
